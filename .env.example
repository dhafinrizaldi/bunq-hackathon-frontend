# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Groq Whisper API key (hackathon demo only — regenerate after the demo)
# Get one at https://console.groq.com/
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_key_here

# MCP client base URL — use your Mac's LAN IP so a physical phone can reach it
# Find it with: ipconfig getifaddr en0  (macOS)
EXPO_PUBLIC_MCP_BASE=http://YOUR_MAC_LAN_IP:8001

# bunq-api base URL (FastAPI server on port 8000)
EXPO_PUBLIC_API_BASE=http://YOUR_MAC_LAN_IP:8000

# Feature flags — set to "true" to hit real services, "false" to use mocks
EXPO_PUBLIC_USE_REAL_API=false
EXPO_PUBLIC_USE_REAL_STT=true
EXPO_PUBLIC_USE_REAL_MCP=true
